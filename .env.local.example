# Copy this file to .env.local and fill in the values.
# .env.local is gitignored — never commit real credentials.

# --- Auth.js (login sessions) ---
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
AUTH_SECRET=
AUTH_URL=http://localhost:3000
# Dev-only test login (works without Google keys). Set to 0 / remove in normal use.
DEV_LOGIN=0

# --- Token encryption at rest ---
# 32-byte AES-256 key (64 hex characters). Generate with:
# node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=

# --- Role dostępu (opcjonalne) ---
# E-mail promowany do roli "owner" (super-admin) przy logowaniu.
OWNER_EMAIL=
# Adresy (po przecinku) promowane do roli "admin" przy logowaniu.
ADMIN_EMAILS=

# --- Google (login + Calendar read-only) ---
# See README.md, section "Konfiguracja Google" for step-by-step setup.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:3000/api/auth/google/callback

# --- E-mail verification (Resend — https://resend.com) ---
# Bez klucza aplikacja nie wysyła e-maili, tylko wypisuje je do konsoli
# (link weryfikacyjny znajdziesz w logach) — lokalny dev działa bez konfiguracji.
# Link w e-mailu budowany jest na podstawie AUTH_URL (powyżej).
# RESEND_API_KEY=re_xxxxxxxxxxxx
# EMAIL_FROM="Dziennik <noreply@yourdomain.com>"

# Notion is configured per user inside the app (Ustawienia view), not here.

# --- Vercel Blob (przechowywanie zdjęć-dowodów w chmurze) ---
# NIEwymagane lokalnie: bez tego tokenu zdjęcia zapisują się na dysk (./uploads).
# Na Vercelu ustaw go w Storage → Blob (dodaje się automatycznie po podłączeniu
# store'a). Gdy token jest obecny, aplikacja zapisuje zdjęcia do Vercel Blob.
BLOB_READ_WRITE_TOKEN=

# --- Upstash Redis (trwałe limity dla logowania, rejestracji, resetu hasła) ---
# NIEwymagane lokalnie: bez tych zmiennych limity auth spadają na licznik
# w pamięci procesu, który wystarcza w devie (jedna instancja).
# Na Vercelu ustaw je koniecznie: każda instancja serverless ma własny licznik
# w pamięci i zeruje go przy cold starcie, więc realny limit skaluje się z
# liczbą instancji — a to właśnie atak brute-force wymusza skalowanie. Dopiero
# Redis daje limit wspólny dla wszystkich instancji.
# Załóż darmowy store w Vercel → Storage → Upstash Redis (zmienne dodadzą się same).
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
