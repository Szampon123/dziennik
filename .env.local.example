# Copy this file to .env.local and fill in the values.
# .env.local is gitignored — never commit real credentials.

# --- Auth.js (login sessions) ---
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
AUTH_SECRET=
AUTH_URL=http://localhost:3000
# Dev-only test login (works without Google keys). Set to 0 / remove in normal use.
DEV_LOGIN=0

# --- Google (login + Calendar read-only) ---
# See README.md, section "Konfiguracja Google" for step-by-step setup.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:3000/api/auth/google/callback

# Notion is configured per user inside the app (Ustawienia view), not here.
