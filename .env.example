# Skopiuj ten plik do .env  ->  cp .env.example .env
# Zawiera tylko lokalizację bazy (NIE sekret). Sekrety (klucze Google, AUTH_SECRET)
# trzymaj w .env.local — patrz .env.local.example.

# Lokalizacja bazy SQLite (czytana przez Prisma CLI i aplikację).
# Ścieżka względem katalogu prisma/ -> prisma/dev.db
DATABASE_URL="file:./dev.db"
